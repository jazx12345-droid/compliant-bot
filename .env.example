# Copy this file to .env and fill in your values.
# digest.py loads .env automatically if python-dotenv is installed.

# ── SMTP ──────────────────────────────────────────────────────────────────────
# Gmail:   smtp.gmail.com  port 587  (requires an App Password)
# Outlook: smtp.office365.com  port 587
DIGEST_SMTP_HOST=smtp.gmail.com
DIGEST_SMTP_PORT=587
DIGEST_SMTP_TLS=true        # false → SSL-wrapped port 465

DIGEST_SMTP_USER=you@gmail.com
DIGEST_SMTP_PASSWORD=xxxx xxxx xxxx xxxx   # 16-char Gmail App Password

# ── Addresses ─────────────────────────────────────────────────────────────────
DIGEST_FROM=Regulatory Monitor <you@gmail.com>
DIGEST_TO=counsel@example.com,backup@example.com   # comma-separated

# ── Digest behaviour ─────────────────────────────────────────────────────────
DIGEST_SUBJECT_PREFIX=[RegWatch]
DIGEST_HOURS=24             # look-back window
DIGEST_MIN_SCORE=0.5        # 0.5 = 5/10; only enriched items are included

# ── Gemini API ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
